# Backend API base URL для локального запуска.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Backend API base URL для server-side запросов Next.js.
INTERNAL_API_URL=http://localhost:8080

# Публичный ID приложения VK ID для frontend-виджета.
NEXT_PUBLIC_VK_ID_APP_ID=10000000

# Публичный Client ID приложения Яндекс ID для frontend-виджета.
NEXT_PUBLIC_YANDEX_CLIENT_ID=mock_yandex_client_id

# GitHub Secrets для .github/workflows/deploy.yml.
# Эти значения не обязательны для локального .env.

# IP или домен сервера.
# SERVER_HOST=203.0.113.10

# Пользователь для деплоя на сервере.
# SERVER_USER=deploy_user

# Приватный SSH-ключ пользователя SERVER_USER.
# SERVER_DEPLOY_SSH_KEY=-----BEGIN OPENSSH PRIVATE KEY-----MOCK-----END OPENSSH PRIVATE KEY-----

# Публичный ID приложения VK ID для production-сборки.
# NEXT_PUBLIC_VK_ID_APP_ID=10000000

# Публичный Client ID приложения Яндекс ID для production-сборки.
# NEXT_PUBLIC_YANDEX_CLIENT_ID=mock_yandex_client_id
